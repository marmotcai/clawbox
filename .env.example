# ClawBox 环境变量配置
# 复制为 .env 后按需修改

# ========== 设备信息 ==========
DEVICE_ID=clawbox-001
CLAWBOX_VERSION=1.0.0

# ========== 网络 ==========
PROXYCLAW_PORT=20060

# ========== 数据库 ==========
# 必填，建议: openssl rand -base64 24 | tr -d '/+=' | cut -c1-24
PG_PASSWORD=${PG_PASSWORD}

# ========== 管理员 ==========
ADMIN_USERNAME=admin
# 必填，Web UI 管理员密码
ADMIN_PASSWORD=${ADMIN_PASSWORD}

# ========== OTA ==========
OTA_SERVER=https://ota.clawbox.ai

# ========== LLM API Keys (至少填一个) ==========
# OPENAI_API_KEY=sk-xxx
# DEEPSEEK_API_KEY=sk-xxx
# DASHSCOPE_API_KEY=sk-xxx

# ========== 镜像 ==========
# proxyclaw 镜像：使用本地构建
# 首次使用需要先构建 proxyclaw 镜像：
#   git clone https://github.com/marmotcai/proxyclaw.git
#   cd proxyclaw && ./start.sh build
PROXYCLAW_IMAGE=proxyclaw:latest

# ========== 日志 ==========
LOG_LEVEL=info
