# ClawBox 环境变量配置
# 复制为 .env 后按需修改

# ========== 设备信息 ==========
DEVICE_ID=clawbox-001
CLAWBOX_VERSION=1.0.0

# ========== 网络 ==========
PROXYCLAW_PORT=20060

# ========== 数据库 ==========
PG_PASSWORD=clawbox_secret_2026

# ========== 管理员 ==========
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ========== OTA ==========
OTA_SERVER=https://ota.clawbox.ai

# ========== LLM API Keys (至少填一个) ==========
# OPENAI_API_KEY=sk-xxx
# DEEPSEEK_API_KEY=sk-xxx
# DASHSCOPE_API_KEY=sk-xxx

# ========== 镜像 ==========
PROXYCLAW_IMAGE=proxyclaw/proxyclaw:latest
OTA_IMAGE=clawbox/ota-agent:latest

# ========== 日志 ==========
LOG_LEVEL=info
